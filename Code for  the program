#include <stdio.h>
int count(int a[], int n) {
    int number = 0;
   for (int i = 0; i < n; i++) {
    if(a[i] > 0) {
        number++;
    }
   
   }
   return number++;
}
int main(){
    int a[] = {1,2,-3,-4,5,6,7};
    int n = 7;
    printf("The number of positive integer are %d", count(a, 7));
    return 0;
}
